# ═══════════════════════════════════════════════════════════
# design-intel - Configuration
# ═══════════════════════════════════════════════════════════

# ── Primary LLM (used for standard critique) ──
LLM_PROVIDER=claude
LLM_MODEL=claude-sonnet-4-20250514

# ── API Keys (set the ones you have) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=

# ── Ensemble Mode (--ensemble flag) ──
# Comma-separated list of models to run in parallel.
# Each model produces an independent critique, then a synthesis
# agent merges the findings into a consensus report.
#
# Format: provider/model or just model (uses LLM_PROVIDER prefix)
# Examples:
#   ENSEMBLE_MODELS=anthropic/claude-sonnet-4-20250514,openai/gpt-4o
#   ENSEMBLE_MODELS=anthropic/claude-sonnet-4-20250514,anthropic/claude-opus-4-20250514,openai/gpt-4o
#   ENSEMBLE_MODELS=ollama/llama3.2-vision,groq/llama-3.3-70b-versatile
#
ENSEMBLE_MODELS=anthropic/claude-sonnet-4-20250514

# ── Model-Specific Notes ──
#
# FREE / low-cost options:
#   groq/llama-3.3-70b-versatile     - Free tier available (no vision)
#   groq/llama-3.2-90b-vision-preview - Free tier, vision capable
#   deepseek/deepseek-chat            - Very low cost ($0.14/M input)
#   together/meta-llama/Llama-3.3-70B-Instruct-Turbo - Low cost
#   ollama/llama3.2-vision            - Free, runs locally
#   ollama/gemma3                     - Free, runs locally
#   openrouter/google/gemini-2.5-flash - Free tier via OpenRouter
#   openrouter/mistralai/mistral-small - Free tier via OpenRouter
#
# PAID (best quality):
#   anthropic/claude-sonnet-4-20250514  - Strong all-round
#   anthropic/claude-opus-4-20250514    - Deepest reasoning
#   openai/gpt-4o                       - Strong vision + analysis
#   openai/gpt-4o-mini                  - Budget option, still capable
#   google/gemini-2.5-pro               - Strong, needs GOOGLE_API_KEY
#   mistral/mistral-large-latest        - Strong, needs MISTRAL_API_KEY
#
# Recommended ensemble (best coverage for cost):
#   ENSEMBLE_MODELS=anthropic/claude-sonnet-4-20250514,openai/gpt-4o-mini,groq/llama-3.3-70b-versatile

# ── Knowledge Retrieval ──
KNOWLEDGE_RETRIEVAL_LIMIT=2000
RETRIEVAL_TOP_K=5

# ── Output ──
OUTPUT_FORMAT=markdown
CRITIQUE_SEVERITY_THRESHOLD=low
